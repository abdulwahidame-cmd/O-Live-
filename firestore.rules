rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "abdulwahidame@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUrl(url) {
      return url is string &&
        (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'username', 'followersCount', 'followingCount', 'likesCount', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'username', 'name', 'avatar', 'bio', 'followersCount', 'followingCount', 'likesCount', 'createdAt', 'updatedAt', 'role']) &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 30 &&
             data.followersCount is number && data.followersCount >= 0 &&
             data.followingCount is number && data.followingCount >= 0 &&
             data.likesCount is number && data.likesCount >= 0 &&
             data.createdAt is timestamp &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('name' in data) || (data.name is string && data.name.size() <= 100)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 500)) &&
             (!('avatar' in data) || isValidUrl(data.avatar)) &&
             (!('role' in data) || (data.role is string && data.role in ['admin', 'user']));
    }

    function isValidVideo(data) {
      return hasRequiredFields(['id', 'uid', 'username', 'url', 'thumbnail', 'likes', 'comments', 'shares', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'uid', 'username', 'url', 'thumbnail', 'description', 'likes', 'comments', 'shares', 'musicName', 'category', 'tags', 'createdAt']) &&
             data.id is string &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() <= 50 &&
             isValidUrl(data.url) &&
             isValidUrl(data.thumbnail) &&
             data.likes is number && data.likes >= 0 &&
             data.comments is number && data.comments >= 0 &&
             data.shares is number && data.shares >= 0 &&
             data.createdAt is timestamp &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             (!('musicName' in data) || (data.musicName is string && data.musicName.size() <= 100)) &&
             (!('category' in data) || (data.category is string && data.category.size() <= 50)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 20));
    }

    function isValidComment(data) {
      return hasRequiredFields(['id', 'videoId', 'uid', 'username', 'text', 'likes', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'videoId', 'uid', 'username', 'text', 'likes', 'createdAt']) &&
             data.id is string &&
             data.videoId is string &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() <= 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.likes is number && data.likes >= 0 &&
             data.createdAt is timestamp;
    }

    function isValidNotification(data) {
      return hasRequiredFields(['recipientUid', 'type', 'senderUid', 'username', 'message', 'isRead', 'createdAt']) &&
             hasOnlyAllowedFields(['recipientUid', 'type', 'senderUid', 'username', 'message', 'isRead', 'createdAt', 'avatar']) &&
             data.recipientUid is string &&
             data.type in ['like', 'comment', 'follow', 'live'] &&
             data.senderUid == request.auth.uid &&
             data.username is string && data.username.size() <= 50 &&
             data.message is string && data.message.size() <= 500 &&
             data.isRead is bool &&
             data.createdAt is timestamp &&
             (!('avatar' in data) || isValidUrl(data.avatar));
    }

    function isValidLiveStream(data) {
      return hasRequiredFields(['uid', 'username', 'title', 'category', 'isLive', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'username', 'title', 'category', 'isLive', 'createdAt', 'thumbnail', 'viewers', 'likes']) &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() <= 50 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.category is string && data.category.size() <= 50 &&
             data.isLive is bool &&
             data.createdAt is timestamp &&
             (!('thumbnail' in data) || isValidUrl(data.thumbnail)) &&
             (!('viewers' in data) || (data.viewers is number && data.viewers >= 0)) &&
             (!('likes' in data) || (data.likes is number && data.likes >= 0));
    }

    function isValidLiveChat(data) {
      return hasRequiredFields(['streamId', 'uid', 'username', 'text', 'createdAt']) &&
             hasOnlyAllowedFields(['streamId', 'uid', 'username', 'text', 'createdAt', 'color']) &&
             data.streamId is string &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() <= 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.createdAt is timestamp &&
             (!('color' in data) || (data.color is string && data.color.size() <= 50));
    }

    function isValidLike(data) {
      return hasRequiredFields(['userId', 'targetId', 'type', 'createdAt']) &&
             hasOnlyAllowedFields(['userId', 'targetId', 'type', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.targetId is string &&
             data.type in ['video', 'live_stream'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                       request.resource.data.createdAt == resource.data.createdAt &&
                       request.resource.data.uid == resource.data.uid) || isAdmin();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidVideo(request.resource.data);
      allow update: if (isOwner(resource.data.uid) && isValidVideo(request.resource.data) &&
                       request.resource.data.uid == resource.data.uid &&
                       request.resource.data.createdAt == resource.data.createdAt) || isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow update: if (isOwner(resource.data.uid) && isValidComment(request.resource.data) &&
                       request.resource.data.uid == resource.data.uid &&
                       request.resource.data.createdAt == resource.data.createdAt) || isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.recipientUid);
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isOwner(resource.data.recipientUid) && 
                       isValidNotification(request.resource.data) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isOwner(resource.data.recipientUid);
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.followerUid == request.auth.uid &&
                       request.resource.data.createdAt is timestamp;
      allow delete: if isAuthenticated() && resource.data.followerUid == request.auth.uid;
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidLike(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /live_streams/{streamId} {
      allow get, list: if true;
      allow create: if isAuthenticated() && isValidLiveStream(request.resource.data);
      allow update: if (isOwner(resource.data.uid) && isValidLiveStream(request.resource.data) &&
                       request.resource.data.uid == resource.data.uid &&
                       request.resource.data.createdAt == resource.data.createdAt) || isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /live_chats/{chatId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidLiveChat(request.resource.data);
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
